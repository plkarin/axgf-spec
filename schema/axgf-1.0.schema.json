{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axgf.org/schema/1.0/axgf.schema.json",
  "title": "AXGF 1.0 Schema",
  "description": "JSON Schema for the Ancestral Exchange and Genealogy Format v1.0",
  "version": "1.0.0",

  "$defs": {

    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "Lowercase UUID v4"
    },

    "iso8601": {
      "type": "string",
      "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2}(T[0-9]{2}:[0-9]{2}:[0-9]{2}(Z|[+-][0-9]{2}:[0-9]{2})?)?)?)?$",
      "description": "ISO 8601 datetime or partial date"
    },

    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score 0.0 (uncertain) to 1.0 (certain)"
    },

    "bcp47_lang": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2,3})?$",
      "description": "BCP 47 language code"
    },

    "visibility": {
      "type": "string",
      "enum": ["public", "members", "contributors", "private"]
    },

    "text_direction": {
      "type": "string",
      "enum": ["ltr", "rtl"]
    },

    "calendar": {
      "type": "string",
      "enum": [
        "gregorian", "julian", "hebrew", "hijri", "persian",
        "chinese", "ethiopian", "japanese_era", "republican_french", "roman"
      ]
    },

    "date_precision": {
      "type": "string",
      "enum": ["exact", "month", "year", "decade", "quarter_century", "century", "unknown"]
    },

    "axgf_date": {
      "type": "object",
      "properties": {
        "value":      { "$ref": "#/$defs/iso8601" },
        "calendar":   { "$ref": "#/$defs/calendar", "default": "gregorian" },
        "precision":  { "$ref": "#/$defs/date_precision" },
        "circa":      { "type": "boolean", "default": false },
        "confidence": { "$ref": "#/$defs/confidence" },
        "note":       { "type": ["string", "null"] },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value":    { "type": "string" },
              "calendar": { "$ref": "#/$defs/calendar" },
              "era":      { "type": "string" },
              "era_year": { "type": "integer" }
            },
            "required": ["value", "calendar"]
          }
        },
        "range": {
          "type": ["object", "null"],
          "properties": {
            "earliest": { "$ref": "#/$defs/axgf_date" },
            "latest":   { "$ref": "#/$defs/axgf_date" },
            "note":     { "type": "string" }
          }
        }
      }
    },

    "name_component_type": {
      "type": "string",
      "enum": [
        "given_name", "family_name", "patronymic", "matronymic",
        "nasab", "laqab", "kunya", "nisbah",
        "nickname", "alias", "religious_name", "pen_name"
      ]
    },

    "name_component": {
      "type": "object",
      "required": ["type", "value", "order"],
      "properties": {
        "type":         { "$ref": "#/$defs/name_component_type" },
        "value":        { "type": "string", "minLength": 1 },
        "value_latin":  { "type": ["string", "null"] },
        "reading":      { "type": ["string", "null"] },
        "reading_system": {
          "type": ["string", "null"],
          "enum": ["hiragana", "katakana", "pinyin", "jyutping", "ipa", "revised_romanization", null]
        },
        "order":        { "type": "integer", "minimum": 1 },
        "derived_from": { "$ref": "#/$defs/uuid" },
        "derivation_type": {
          "type": ["string", "null"],
          "enum": ["patronymic", "matronymic", null]
        }
      }
    },

    "axgf_name": {
      "type": "object",
      "required": ["display", "components"],
      "properties": {
        "display":        { "type": "string", "minLength": 1 },
        "display_latin":  { "type": ["string", "null"] },
        "culture":        { "$ref": "#/$defs/bcp47_lang" },
        "direction":      { "$ref": "#/$defs/text_direction" },
        "display_order":  { "type": "string", "enum": ["given_first", "family_first"] },
        "reading":        { "type": ["string", "null"] },
        "reading_system": { "type": ["string", "null"] },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/name_component" }
        }
      }
    },

    "document_link": {
      "type": "object",
      "required": ["document_id"],
      "properties": {
        "document_id": { "$ref": "#/$defs/uuid" },
        "role":        { "type": "string" },
        "note":        { "type": ["string", "null"] },
        "date":        { "type": ["string", "null"] }
      }
    },

    "entity_ref": {
      "type": "object",
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": { "type": "string", "enum": ["person", "family", "event", "link", "source"] },
        "entity_id":   { "$ref": "#/$defs/uuid" },
        "role":        { "type": "string" },
        "confidence":  { "$ref": "#/$defs/confidence" }
      }
    },

    "ai_hypothesis": {
      "type": "object",
      "required": ["id", "claim", "confidence", "status"],
      "properties": {
        "id":           { "type": "string" },
        "claim":        { "type": "string" },
        "confidence":   { "$ref": "#/$defs/confidence" },
        "status":       { "type": "string", "enum": ["pending", "confirmed", "rejected", "investigating"] },
        "evidence":     { "type": ["string", "null"] },
        "created_at":   { "type": "string" },
        "reviewed_at":  { "type": ["string", "null"] },
        "reviewed_by":  { "type": ["string", "null"] }
      }
    },

    "base_entity": {
      "type": "object",
      "required": ["id", "type", "axgf_version"],
      "properties": {
        "id":            { "$ref": "#/$defs/uuid" },
        "type":          { "type": "string" },
        "axgf_version":  { "type": "string", "const": "1.0" },
        "created_at":    { "type": "string" },
        "updated_at":    { "type": "string" },
        "version_num":   { "type": "integer", "minimum": 1, "default": 1 },
        "created_by":    { "type": ["string", "null"] },
        "tags":          { "type": "array", "items": { "type": "string" } },
        "extensions":    { "type": "object" }
      }
    }
  },

  "oneOf": [
    { "$ref": "#/$defs/manifest" },
    { "$ref": "#/$defs/person" },
    { "$ref": "#/$defs/family" },
    { "$ref": "#/$defs/event" },
    { "$ref": "#/$defs/link" },
    { "$ref": "#/$defs/occupation" },
    { "$ref": "#/$defs/source" },
    { "$ref": "#/$defs/place" },
    { "$ref": "#/$defs/document" }
  ],

  "$defs": {

    "manifest": {
      "type": "object",
      "required": ["axgf", "created_at", "stats"],
      "properties": {
        "axgf":       { "type": "string", "const": "1.0" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "generator": {
          "type": "object",
          "properties": {
            "name":    { "type": "string" },
            "version": { "type": "string" },
            "url":     { "type": "string" }
          }
        },
        "family": {
          "type": "object",
          "properties": {
            "name":            { "type": "string" },
            "description":     { "type": ["string", "null"] },
            "primary_culture": { "type": "string" },
            "primary_place":   { "type": ["string", "null"] },
            "time_span": {
              "type": "object",
              "properties": {
                "earliest": { "type": "string" },
                "latest":   { "type": "string" }
              }
            }
          }
        },
        "stats": {
          "type": "object",
          "required": ["persons"],
          "properties": {
            "persons":     { "type": "integer", "minimum": 0 },
            "families":    { "type": "integer", "minimum": 0 },
            "events":      { "type": "integer", "minimum": 0 },
            "links":       { "type": "integer", "minimum": 0 },
            "occupations": { "type": "integer", "minimum": 0 },
            "sources":     { "type": "integer", "minimum": 0 },
            "places":      { "type": "integer", "minimum": 0 },
            "documents":   { "type": "integer", "minimum": 0 }
          }
        },
        "privacy": {
          "type": "object",
          "properties": {
            "contains_living_persons": { "type": "boolean" },
            "living_persons_redacted": { "type": "boolean" },
            "gdpr_compliant":          { "type": "boolean" }
          }
        },
        "license": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "url":  { "type": ["string", "null"] },
            "note": { "type": ["string", "null"] }
          }
        }
      }
    },

    "person": {
      "allOf": [{ "$ref": "#/$defs/base_entity" }],
      "properties": {
        "type": { "const": "person" },
        "identity": {
          "type": "object",
          "required": ["name", "gender", "is_living"],
          "properties": {
            "name":  { "$ref": "#/$defs/axgf_name" },
            "names": {
              "type": "array",
              "items": {
                "allOf": [{ "$ref": "#/$defs/axgf_name" }],
                "properties": {
                  "type":         { "type": "string", "enum": ["birth","married","alias","nickname","transliteration","religious","pen_name","other"] },
                  "source_id":    { "$ref": "#/$defs/uuid" },
                  "confidence":   { "$ref": "#/$defs/confidence" },
                  "valid_from":   { "type": ["string", "null"] },
                  "valid_until":  { "type": ["string", "null"] },
                  "note":         { "type": ["string", "null"] }
                }
              }
            },
            "gender": {
              "type": "object",
              "required": ["value"],
              "properties": {
                "value": { "type": "string", "enum": ["M", "F", "NB", "U"] },
                "note":  { "type": ["string", "null"] }
              }
            },
            "is_living":  { "type": "boolean" },
            "visibility": { "$ref": "#/$defs/visibility" }
          }
        },
        "birth": {
          "type": ["object", "null"],
          "properties": {
            "date":       { "$ref": "#/$defs/axgf_date" },
            "place_id":   { "$ref": "#/$defs/uuid" },
            "confidence": { "$ref": "#/$defs/confidence" },
            "source_id":  { "$ref": "#/$defs/uuid" },
            "event_id":   { "$ref": "#/$defs/uuid" }
          }
        },
        "death": {
          "type": ["object", "null"],
          "properties": {
            "date":       { "$ref": "#/$defs/axgf_date" },
            "place_id":   { "$ref": "#/$defs/uuid" },
            "cause":      { "type": ["string", "null"] },
            "confidence": { "$ref": "#/$defs/confidence" },
            "source_id":  { "$ref": "#/$defs/uuid" },
            "event_id":   { "$ref": "#/$defs/uuid" }
          }
        },
        "bio":       { "type": ["string", "null"] },
        "notes":     { "type": ["string", "null"] },
        "documents": { "type": "array", "items": { "$ref": "#/$defs/document_link" } },
        "ai": {
          "type": ["object", "null"],
          "properties": {
            "vault_page":            { "type": ["string", "null"] },
            "embedding_model":       { "type": ["string", "null"] },
            "embedding_updated_at":  { "type": ["string", "null"] },
            "hypotheses": {
              "type": "array",
              "items": { "$ref": "#/$defs/ai_hypothesis" }
            }
          }
        }
      },
      "required": ["identity"]
    },

    "family": {
      "allOf": [{ "$ref": "#/$defs/base_entity" }],
      "properties": {
        "type":        { "const": "family" },
        "name":        { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "union": {
          "type": "object",
          "required": ["type", "persons"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["marriage","civil_union","cohabitation","religious_only","polygamous","unknown"]
            },
            "status": {
              "type": ["string", "null"],
              "enum": ["active","ended_by_death","ended_by_divorce","ended_by_separation","annulled","unknown", null]
            },
            "persons": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["person_id", "role"],
                "properties": {
                  "person_id": { "$ref": "#/$defs/uuid" },
                  "role":      { "type": "string" }
                }
              }
            },
            "start": {
              "type": ["object", "null"],
              "properties": {
                "date":     { "$ref": "#/$defs/axgf_date" },
                "place_id": { "$ref": "#/$defs/uuid" },
                "event_id": { "$ref": "#/$defs/uuid" }
              }
            },
            "end": {
              "type": ["object", "null"],
              "properties": {
                "date":   { "$ref": "#/$defs/axgf_date" },
                "reason": { "type": ["string", "null"] },
                "note":   { "type": ["string", "null"] }
              }
            },
            "confidence": { "$ref": "#/$defs/confidence" },
            "source_id":  { "$ref": "#/$defs/uuid" }
          }
        },
        "children": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["person_id"],
            "properties": {
              "person_id":   { "$ref": "#/$defs/uuid" },
              "birth_order": { "type": ["integer", "null"] },
              "confidence":  { "$ref": "#/$defs/confidence" },
              "note":        { "type": ["string", "null"] }
            }
          }
        },
        "documents": { "type": "array", "items": { "$ref": "#/$defs/document_link" } },
        "notes":     { "type": ["string", "null"] },
        "ai": {
          "type": ["object", "null"],
          "properties": {
            "vault_page": { "type": ["string", "null"] }
          }
        }
      },
      "required": ["union"]
    },

    "event": {
      "allOf": [{ "$ref": "#/$defs/base_entity" }],
      "properties": {
        "type":        { "const": "event" },
        "category": {
          "type": "string",
          "enum": [
            "birth","death","marriage","divorce","adoption",
            "migration","naturalization","military","incarceration",
            "name_change","census","legal","religious","social","historical","other"
          ]
        },
        "subcategory": { "type": ["string", "null"] },
        "date":        { "$ref": "#/$defs/axgf_date" },
        "place_id":    { "$ref": "#/$defs/uuid" },
        "participants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["entity_type", "entity_id", "role"],
            "properties": {
              "entity_type": { "type": "string", "enum": ["person","family","organization"] },
              "entity_id":   { "$ref": "#/$defs/uuid" },
              "role":        { "type": "string" },
              "confidence":  { "$ref": "#/$defs/confidence" }
            }
          }
        },
        "description": { "type": ["string", "null"] },
        "documents":   { "type": "array", "items": { "$ref": "#/$defs/document_link" } },
        "confidence":  { "$ref": "#/$defs/confidence" },
        "source_id":   { "$ref": "#/$defs/uuid" },
        "ai": {
          "type": ["object", "null"],
          "properties": {
            "vault_page": { "type": ["string", "null"] }
          }
        }
      },
      "required": ["category", "date"]
    },

    "link": {
      "allOf": [{ "$ref": "#/$defs/base_entity" }],
      "properties": {
        "type": { "const": "link" },
        "from": {
          "type": "object",
          "required": ["entity_type", "entity_id"],
          "properties": {
            "entity_type": { "type": "string", "enum": ["person","family","event"] },
            "entity_id":   { "$ref": "#/$defs/uuid" }
          }
        },
        "to": {
          "type": "object",
          "required": ["entity_type", "entity_id"],
          "properties": {
            "entity_type": { "type": "string", "enum": ["person","family","event"] },
            "entity_id":   { "$ref": "#/$defs/uuid" }
          }
        },
        "label":         { "type": "string", "minLength": 1 },
        "label_reverse": { "type": ["string", "null"] },
        "category": {
          "type": ["string", "null"],
          "enum": ["spiritual","professional","social","legal","medical","educational","conflict","other", null]
        },
        "bidirectional": { "type": "boolean", "default": false },
        "valid_from": {
          "type": ["object", "null"],
          "properties": {
            "date":     { "$ref": "#/$defs/axgf_date" },
            "event_id": { "$ref": "#/$defs/uuid" }
          }
        },
        "valid_until": {
          "type": ["object", "null"],
          "properties": {
            "date":     { "$ref": "#/$defs/axgf_date" },
            "event_id": { "$ref": "#/$defs/uuid" }
          }
        },
        "confidence":  { "$ref": "#/$defs/confidence" },
        "source_id":   { "$ref": "#/$defs/uuid" },
        "note":        { "type": ["string", "null"] },
        "visibility":  { "$ref": "#/$defs/visibility" }
      },
      "required": ["from", "to", "label"]
    },

    "occupation": {
      "allOf": [{ "$ref": "#/$defs/base_entity" }],
      "properties": {
        "type":       { "const": "occupation" },
        "person_id":  { "$ref": "#/$defs/uuid" },
        "title":      { "type": "string", "minLength": 1 },
        "title_latin":      { "type": ["string", "null"] },
        "title_normalized": { "type": ["string", "null"] },
        "employer": {
          "type": ["object", "null"],
          "properties": {
            "name":     { "type": "string" },
            "place_id": { "$ref": "#/$defs/uuid" }
          }
        },
        "place_id":   { "$ref": "#/$defs/uuid" },
        "valid_from": {
          "type": ["object", "null"],
          "properties": { "date": { "$ref": "#/$defs/axgf_date" } }
        },
        "valid_until": {
          "type": ["object", "null"],
          "properties": { "date": { "$ref": "#/$defs/axgf_date" } }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "source_id":  { "$ref": "#/$defs/uuid" },
        "note":       { "type": ["string", "null"] }
      },
      "required": ["person_id", "title"]
    },

    "source": {
      "allOf": [{ "$ref": "#/$defs/base_entity" }],
      "properties": {
        "type":        { "const": "source" },
        "title":       { "type": "string" },
        "source_type": {
          "type": "string",
          "enum": [
            "birth_certificate","death_certificate","marriage_certificate",
            "census","baptism_record","burial_record","will","land_record",
            "military_record","immigration_record","naturalization",
            "passport","photograph","letter","diary","newspaper",
            "oral_tradition","dna","family_bible","gravestone",
            "published_genealogy","other"
          ]
        },
        "reliability": {
          "type": "string",
          "enum": ["primary","secondary","derivative","authored","oral","unknown"]
        },
        "confidence":  { "$ref": "#/$defs/confidence" },
        "status": {
          "type": ["string", "null"],
          "enum": ["verified","unverified","lost","known_missing", null]
        },
        "repository": {
          "type": ["object", "null"],
          "properties": {
            "name":      { "type": "string" },
            "location":  { "type": ["string", "null"] },
            "url":       { "type": ["string", "null"] },
            "reference": { "type": ["string", "null"] }
          }
        },
        "date":        { "$ref": "#/$defs/axgf_date" },
        "place_id":    { "$ref": "#/$defs/uuid" },
        "document_id": { "$ref": "#/$defs/uuid" },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_id", "field"],
            "properties": {
              "source_id":       { "$ref": "#/$defs/uuid" },
              "field":           { "type": "string" },
              "this_value":      { "type": "string" },
              "conflict_value":  { "type": "string" },
              "resolution":      { "type": ["string", "null"], "enum": ["this_preferred","other_preferred","unresolved", null] },
              "resolution_note": { "type": ["string", "null"] }
            }
          }
        },
        "transcription": { "type": ["string", "null"] },
        "language":      { "type": ["string", "null"] },
        "script":        { "type": ["string", "null"] },
        "dna": {
          "type": ["object", "null"],
          "properties": {
            "test_provider": { "type": "string" },
            "test_type":     { "type": "string", "enum": ["autosomal","y_dna","mt_dna","x_dna"] },
            "test_date":     { "type": ["string", "null"] },
            "kit_id":        { "type": ["string", "null"] },
            "match": {
              "type": ["object", "null"],
              "properties": {
                "person_id":             { "$ref": "#/$defs/uuid" },
                "shared_cm":             { "type": "number" },
                "shared_percent":        { "type": "number" },
                "predicted_relationship":{ "type": "string" },
                "confidence":            { "$ref": "#/$defs/confidence" }
              }
            }
          }
        },
        "note": { "type": ["string", "null"] }
      },
      "required": ["title", "source_type", "reliability"]
    },

    "place": {
      "allOf": [{ "$ref": "#/$defs/base_entity" }],
      "properties": {
        "type": { "const": "place" },
        "names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["lang", "value"],
            "properties": {
              "lang":       { "type": "string" },
              "value":      { "type": "string" },
              "is_primary": { "type": "boolean", "default": false }
            }
          }
        },
        "place_type": {
          "type": ["string", "null"],
          "enum": ["continent","country","region","department","city","village","district","street","building","farm","island","historical","unknown", null]
        },
        "region":          { "type": ["string", "null"] },
        "country_current": { "type": ["string", "null"] },
        "coordinates": {
          "type": ["object", "null"],
          "properties": {
            "lat":       { "type": "number", "minimum": -90,  "maximum": 90 },
            "lon":       { "type": "number", "minimum": -180, "maximum": 180 },
            "precision": { "type": ["string", "null"] }
          }
        },
        "country_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["country"],
            "properties": {
              "country": { "type": "string" },
              "from":    { "type": ["string", "null"] },
              "until":   { "type": ["string", "null"] },
              "note":    { "type": ["string", "null"] }
            }
          }
        },
        "identifiers": {
          "type": ["object", "null"],
          "properties": {
            "wikidata": { "type": "string" },
            "geonames": { "type": "string" },
            "insee":    { "type": "string" }
          }
        },
        "note": { "type": ["string", "null"] }
      },
      "required": ["names"]
    },

    "document": {
      "allOf": [{ "$ref": "#/$defs/base_entity" }],
      "properties": {
        "type":          { "const": "document" },
        "filename":      { "type": "string" },
        "mime_type":     { "type": "string" },
        "document_type": {
          "type": "string",
          "enum": [
            "photo","birth_certificate","death_certificate","marriage_certificate",
            "census_page","baptism_record","military_record","will","land_record",
            "letter","diary","newspaper_clipping","gravestone_photo",
            "family_tree_drawing","audio","video","other"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["present","referenced","known_missing","lost","unknown"]
        },
        "file": {
          "type": ["object", "null"],
          "properties": {
            "path":       { "type": "string" },
            "size_bytes": { "type": "integer" },
            "sha256":     { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          }
        },
        "url":     { "type": ["string", "null"] },
        "date":    { "$ref": "#/$defs/axgf_date" },
        "place_id":{ "$ref": "#/$defs/uuid" },
        "language":{ "type": ["string", "null"] },
        "linked_to": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["entity_type", "entity_id"],
            "properties": {
              "entity_type": { "type": "string", "enum": ["person","family","event","source"] },
              "entity_id":   { "$ref": "#/$defs/uuid" },
              "role":        { "type": "string" }
            }
          }
        },
        "ocr": {
          "type": ["object", "null"],
          "properties": {
            "text":       { "type": "string" },
            "confidence": { "$ref": "#/$defs/confidence" },
            "language":   { "type": "string" },
            "engine":     { "type": ["string", "null"] }
          }
        },
        "ai": {
          "type": ["object", "null"],
          "properties": {
            "summary": { "type": ["string", "null"] },
            "suggested_links": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "entity_type": { "type": "string" },
                  "entity_id":   { "$ref": "#/$defs/uuid" },
                  "confidence":  { "$ref": "#/$defs/confidence" },
                  "reason":      { "type": "string" }
                }
              }
            }
          }
        },
        "caption": { "type": ["string", "null"] },
        "note":    { "type": ["string", "null"] }
      },
      "required": ["filename", "mime_type", "document_type", "status"]
    }

  }
}
